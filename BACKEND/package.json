{
  "name": "g360-backend",
  "version": "1.0.0",
  "description": "G360 Enterprise Management Platform API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:add-expense-rejection-columns": "node src/scripts/add-expense-rejection-columns-all-tenants.js",
    "prisma:studio": "prisma studio",
    "seed": "node src/prisma/seed.js",
    "seed:gantt-demo": "node src/scripts/seed-gantt-demo-project.js",
    "seed:devcraft": "node src/scripts/seed-model-tenant-devcraft.js",
    "catalog:tenants": "node scripts/debug-tenants.js",
    "seed:catalog": "node seed-catalog.js",
    "seed:catalog:all": "node src/scripts/seed-catalog-all-tenants.js",
    "seed:suppliers:all": "node src/scripts/seed-suppliers-all-tenants.js",
    "seed:three-areas:all": "node src/scripts/seed-three-areas-all-tenants.js",
    "seed:approvals-showcase:all": "node src/scripts/seed-approvals-showcase-all-tenants.js",
    "seed:portal-tickets:all": "node src/scripts/seed-portal-tickets-showcase-all-tenants.js",
    "seed:portal-tickets:reset": "node src/scripts/seed-portal-tickets-showcase-all-tenants.js --reset",
    "db:sanitize-labels": "node src/scripts/sanitize-production-like-labels.js",
    "db:migrate-org-codes": "node src/scripts/migrate-short-org-codes.js",
    "db:migrate-ticket-codes": "node src/scripts/migrate-ticket-codes-legacy-format.js",
    "deploy:tenants": "node src/scripts/migrate-all-tenants.js && node src/scripts/seed-catalog-all-tenants.js",
    "reset:admin-password": "node src/scripts/reset-admin-password-all-tenants.js",
    "test": "jest",
    "test:integration": "jest --config jest-integration.config.js --runInBand",
    "prisma:test": "dotenv -e .env.test -- npx prisma db push",
    "test:load:auth": "npx artillery run tests/load/login.yml",
    "test:load:projects": "npx artillery run tests/load/projects.yml"
  },
  "keywords": [
    "erp",
    "management",
    "enterprise",
    "g360"
  ],
  "author": "G360 Dev Team",
  "license": "ISC",
  "dependencies": {
    "@azure/msal-node": "^3.8.4",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "imapflow": "^1.2.15",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "luxon": "^3.7.2",
    "mailparser": "^3.9.4",
    "marked": "^17.0.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "pg": "^8.11.3",
    "selfsigned": "^5.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "artillery": "^2.0.30",
    "axios": "^1.13.2",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.0.3",
    "prisma": "^5.9.1",
    "supertest": "^7.1.4"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "node src/prisma/seed.js"
  }
}
