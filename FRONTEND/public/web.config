<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    
    <!-- Configuração de Segurança de Cabeçalhos (Helmet básico no IIS) -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Xss-Protection" value="1; mode=block" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        
        <!-- ======================================================= -->
        <!-- REWRITE DO REACT (SPA ROUTING) -->
        <!-- Conserta o problema do Botão F5 / Refresh Page em rotas profundas -->
        <!-- ======================================================= -->
        <!-- Nota: A regra de Reverse Proxy foi removida deste arquivo, pois você informou que já possui no seu painel do IIS -->
        <rule name="React SPA Routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- Se NÃO for um arquivo físico (ex: imagem ou js no disco) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- Se NÃO for um diretório físico -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <!-- Exceção: Ignorar /api para que as requisições fluam para o Proxy Revolto nativo que você já configurou no IIS -->
            <add input="{URL}" matchType="Pattern" pattern="^/api/" negate="true" />
          </conditions>
          <!-- Redirecione para a raiz (index.html), e o pacote do React Router cuidará da tela -->
          <action type="Rewrite" url="/index.html" />
        </rule>
        
      </rules>
    </rewrite>

    <!-- Garante que erros de IIS também usem o SPA -->
    <httpErrors errorMode="Custom" defaultResponseMode="ExecuteURL">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>
    
  </system.webServer>
</configuration>
